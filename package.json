{
  "name": "actions-usage",
  "version": "0.0.0-development",
  "description": "Show GitHub Actions usage metrics per developer for any repo",
  "type": "module",
  "bin": {
    "actions-usage": "./dist/cli.cjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "github",
    "actions",
    "usage",
    "metrics",
    "ci",
    "billing",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gary-quinn/actions-usage.git"
  },
  "license": "MIT",
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
